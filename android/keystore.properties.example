# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored and should never be committed.

# Debug signing (standard Android defaults)
MYAPP_DEBUG_STORE_PASSWORD=android
MYAPP_DEBUG_KEY_ALIAS=androiddebugkey
MYAPP_DEBUG_KEY_PASSWORD=android

# Release signing (your production keystore)
MYAPP_RELEASE_STORE_PASSWORD=your_release_store_password
MYAPP_RELEASE_KEY_ALIAS=your_release_key_alias
MYAPP_RELEASE_KEY_PASSWORD=your_release_key_password
